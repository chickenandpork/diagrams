digraph G {

  subgraph cluster_0 {
    label = "Gitlab SaaS"
    node [style=filled];
    color=orange

    saas [ name="gitlab.com" ]
  }

  subgraph cluster_1 {
    label = "host"
    color=green

    node [style=filled];
    executor [ name="docker-executor" ]

    subgraph cluster_1_2 {
      label = "Docker CNI"
      # build
      { rank=same build->"other\ncontainer" [ style=dotted headlabel="deploy" ]; }
    }
      saas -> executor -> saas [ style=dotted ];
      executor -> build [ style=dotted headlabel="deploy" ];
  }
}
